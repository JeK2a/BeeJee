{
    "name": "beejee/tasks-demo",
    "description": "PHP MVC task list with hardened auth and database layer",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "application/lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php bin/migrate.php",
        "analyse": "phpstan analyse --memory-limit=256M",
        "ci": [
            "@analyse",
            "@test"
        ]
    }
}
