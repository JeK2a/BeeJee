# Copy to .env and adjust. Never commit .env with real secrets.

APP_DEBUG=0

# Apply database/migrations on web requests (disable in production if you run bin/migrate.php only)
RUN_MIGRATIONS=1

# sqlite (default) or mysql
DB_DRIVER=sqlite
DB_PATH=/workspace/storage/database.sqlite

# MySQL example:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_NAME=tasks
# DB_USER=tasks
# DB_PASSWORD=secret
# DB_CHARSET=utf8mb4
